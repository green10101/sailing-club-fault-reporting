{
    "name": "sailing-club-fault-reporting",
    "description": "A web application for reporting faults in a sailing club's fleet of hire boats.",
    "type": "project",
    "require": {
        "php": "^7.4 || ^8.0",
        "monolog/monolog": "^2.0",
        "vlucas/phpdotenv": "^5.0",
        "swiftmailer/swiftmailer": "^6.0",
        "illuminate/database": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}